{
  "name": "foxy-exam",
  "private": true,
  "version": "0.1.0",
  "description": "Foxy Exam — desktop client for proctored exams",
  "author": {
    "name": "Konnn04",
    "email": "trieukon1011@gmail.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "lint": "tsc --noEmit",
    "build": "tsc && vite build",
    "build:electron": "tsc && vite build && electron-builder",
    "release:local": "pnpm run build && electron-builder --publish never",
    "release:linux": "pnpm run build && electron-builder --linux --publish never",
    "release:win": "pnpm run build && electron-builder --win --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.foxyexam.app",
    "productName": "Foxy Exam",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "icon": "public/assets/icons/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}.${ext}",
      "icon": "public/assets/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup.${ext}",
      "icon": "public/assets/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Foxy Exam <trieukon1011@gmail.com>",
      "category": "Education",
      "artifactName": "${productName}.${ext}",
      "icon": "public/assets/icons/icon.png"
    },
    "nsis": {
      "installerIcon": "public/assets/icons/icon.ico",
      "uninstallerIcon": "public/assets/icons/icon.ico"
    },
    "deb": {
      "icon": "public/assets/icons/icon.png"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mediapipe/tasks-audio": "^0.10.34",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@sentry/electron": "^7.11.0",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.4",
    "laravel-echo": "^2.3.4",
    "livekit-client": "^2.18.1",
    "lucide-react": "^0.575.0",
    "medium-zoom": "^1.1.0",
    "next-themes": "^0.4.6",
    "pusher-js": "^8.5.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uiohook-napi": "^1.5.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "uiohook-napi"
    ]
  }
}